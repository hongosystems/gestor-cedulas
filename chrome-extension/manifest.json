{
  "manifest_version": 3,
  "name": "PJN Cargador - Estudio Hisi",
  "version": "1.1.0",
  "description": "Automatiza la carga de escritos en el Portal PJN",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://portalpjn.pjn.gov.ar/*",
    "https://sso.pjn.gov.ar/*",
    "https://escritos.pjn.gov.ar/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://gestor-cedulas.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://sso.pjn.gov.ar/*"],
      "js": ["content_sso.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portalpjn.pjn.gov.ar/*"],
      "js": ["content_pjn.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://escritos.pjn.gov.ar/*"],
      "js": ["content_escritos.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://*.vercel.app/*",
      "https://gestor-cedulas.vercel.app/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
